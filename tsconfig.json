{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true
  },
  "include": ["features/**/*.ts", "config/**/*.ts", "pages/**/*.ts", "pageObjects/**/*.ts"]
}
